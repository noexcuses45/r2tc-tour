{
  "expo": {
    "name": "R2TC Tour",
    "slug": "r2tc-tour",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/boot.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#0b3d1f"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "R2TC Tour uses your location to show GPS distances to the front, middle and back of the green while you play.",
        "NSCameraUsageDescription": "R2TC Tour uses the camera so you can take photos to share in the feed and chats.",
        "NSPhotoLibraryUsageDescription": "R2TC Tour accesses your photos so you can share them in the feed and chats and set a profile picture.",
        "NSMicrophoneUsageDescription": "R2TC Tour uses the microphone to record voice messages in chat."
      },
      "bundleIdentifier": "com.r2tctour.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.r2tctour.app",
      "versionCode": 4,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-location",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow R2TC Tour to access your photos."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "576a616a-851c-4a59-af9f-e80ab0f36e06"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/576a616a-851c-4a59-af9f-e80ab0f36e06"
    }
  }
}